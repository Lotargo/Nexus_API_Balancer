server:
  host: "127.0.0.1"
  port: 8080

auth:
  enabled: true
  public_registration: false
  master_key: "nexus-master-key-2024"
  secret: "change-this-to-a-secure-random-string"
  issuer: "nexus-balancer"
  audience: "api-clients"

pools:
  - name: "openai-pool"
    description: "OpenAI-compatible proxy pool"
    provider: "openai"
    target_url: "https://api.openai.com"
    capacity: 20
    keys:
      - id: "OPENAI_KEY_1"
        rps_limit: 10
        rpd_limit: null
        tpm_limit: 60000
        tpd_limit: null
        max_request_tokens: 16000
        cooldown_on_limit: true
        concurrency: 5
        secret_name: "openai_key_1"
        secret_type: "api_key"

  - name: "gemini-pool"
    description: "Gemini proxy pool with generateContent and SSE support"
    provider: "google"
    target_url: "https://generativelanguage.googleapis.com/v1beta"
    capacity: 10
    keys:
      - id: "GEMINI_KEY_1"
        rps_limit: 5
        rpd_limit: null
        tpm_limit: 30000
        tpd_limit: null
        max_request_tokens: 16000
        cooldown_on_limit: true
        concurrency: 2
        secret_name: "gemini_key_1"
        secret_type: "api_key"
