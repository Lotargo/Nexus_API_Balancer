# Nexus API Balancer Configuration

# Database URL (SQLite)
DATABASE_URL=sqlite:nexus.db

# Admin Secret Key (Used for X-Admin-Key header and admin JWTs)
# Generate a strong secret for production!
ADMIN_API_KEY=super-secret-admin-key-change-me

# Server Settings
PORT=3317
HOST=0.0.0.0

# Auth is configured via config.yaml auth.secret (JWT signing key)
